<Window x:Class="BibliotecaApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:BibliotecaApp.ViewModels"
        Title="Library Management System" 
        Height="700" Width="1100"
        WindowStartupLocation="CenterScreen"
        Background="#121212">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Border Background="#17212B" BorderBrush="#2C3E50" BorderThickness="0 0 1 0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <StackPanel Margin="24 32">
                    <TextBlock Text="📚 LIBRARY" FontSize="20" FontWeight="Black" Foreground="#64B5F6"/>
                    <TextBlock Text="Management Console" FontSize="10" Foreground="#546E7A" Margin="2 2 0 0" FontWeight="SemiBold"/>
                </StackPanel>

                <StackPanel Grid.Row="1" Margin="12 0">
                    <Button Content="  Dashboard" Command="{Binding GoToDashboard}" Style="{StaticResource SidebarButton}"/>
                    <Button Content="  Books"     Command="{Binding GoToBooks}"     Style="{StaticResource SidebarButton}"/>
                    <Button Content="  Loans"     Command="{Binding GoToLoans}"     Style="{StaticResource SidebarButton}"/>
                    
                    <Border Height="1" Background="#2C3E50" Margin="12 16" Visibility="{Binding IsStaff, Converter={StaticResource BoolToVis}}"/>

                    <Button Content="  Accounts"  Command="{Binding GoToUsers}"     Style="{StaticResource SidebarButton}"
                            Visibility="{Binding IsStaff, Converter={StaticResource BoolToVis}}"/>
                    <Button Content="  Fines"     Command="{Binding GoToPenalties}" Style="{StaticResource SidebarButton}"/>
                    <Button Content="  Audit"     Command="{Binding GoToAudit}"     Style="{StaticResource SidebarButton}"
                            Visibility="{Binding IsStaff, Converter={StaticResource BoolToVis}}"/>
                </StackPanel>

                <Border Grid.Row="2" Padding="16 20" Background="#1A2535" BorderBrush="#2C3E50" BorderThickness="0 1 0 0">
                    <DockPanel>
                        <StackPanel DockPanel.Dock="Left" VerticalAlignment="Center">
                            <TextBlock Text="{Binding CurrentUser.FullName}" Foreground="White" FontWeight="SemiBold" FontSize="13"/>
                            <TextBlock Text="{Binding CurrentUser.Role}" Foreground="#90A4AE" FontSize="11"/>
                        </StackPanel>
                        <Button DockPanel.Dock="Right" Command="{Binding LogoutCommand}" 
                                Content="Logout" Style="{StaticResource SecondaryButton}" 
                                Padding="8 4" FontSize="11" HorizontalAlignment="Right"/>
                    </DockPanel>
                </Border>
            </Grid>
        </Border>

        <ContentControl Grid.Column="1" Content="{Binding CurrentPage}"/>
    </Grid>
</Window>

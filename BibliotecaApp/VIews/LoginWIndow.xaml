<Window x:Class="BibliotecaApp.Views.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Library — Authentication"
        Height="520" Width="750"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="#1E2A38">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="320"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Border Background="#17212B" BorderBrush="#2C3E50" BorderThickness="0 0 1 0">
            <DockPanel Margin="20">
                <TextBlock Text="Existing Accounts" 
                           DockPanel.Dock="Top"
                           Foreground="#64B5F6" 
                           FontSize="18" FontWeight="Bold" 
                           Margin="0 0 0 20"/>
                
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <ItemsControl ItemsSource="{Binding Accounts}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Button Command="{Binding DataContext.SelectAccountCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                        CommandParameter="{Binding}"
                                        Margin="0 0 0 10"
                                        Background="#263040"
                                        BorderThickness="0">
                                    <Button.Template>
                                        <ControlTemplate TargetType="Button">
                                            <Border x:Name="border" Background="{TemplateBinding Background}" CornerRadius="6" Padding="12">
                                                <StackPanel Orientation="Horizontal">
                                                    <Grid Width="36" Height="36">
                                                        <Ellipse Fill="#37474F"/>
                                                        <TextBlock Text="👤" VerticalAlignment="Center" HorizontalAlignment="Center" FontSize="18"/>
                                                    </Grid>
                                                    <StackPanel Margin="12 0 0 0">
                                                        <TextBlock Text="{Binding FullName}" Foreground="White" FontWeight="SemiBold"/>
                                                        <TextBlock Text="{Binding Role}" Foreground="#90A4AE" FontSize="11"/>
                                                    </StackPanel>
                                                </StackPanel>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="border" Property="Background" Value="#34495E"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Button.Template>
                                </Button>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </DockPanel>
        </Border>

        <Border Grid.Column="1" CornerRadius="12" Background="#263040" Margin="40">
            <StackPanel VerticalAlignment="Center" Margin="40 30">
                <TextBlock Text="📚" FontSize="52" HorizontalAlignment="Center" Margin="0 0 0 4"/>
                <TextBlock Text="LIBRARY"
                           FontSize="26" FontWeight="Bold"
                           Foreground="#64B5F6"
                           HorizontalAlignment="Center"/>
                <TextBlock Text="Management System"
                           FontSize="12" Foreground="#90A4AE"
                           HorizontalAlignment="Center" Margin="0 2 0 30"/>

                <TextBlock Text="Email" Foreground="#B0BEC5" Margin="0 0 0 4" FontSize="13"/>
                <TextBox x:Name="TxtEmail"
                         Text="{Binding Email, UpdateSourceTrigger=PropertyChanged}"
                         Style="{StaticResource InputStyle}"
                         Margin="0 0 0 16"/>

                <TextBlock Text="Password" Foreground="#B0BEC5" Margin="0 0 0 4" FontSize="13"/>
                <PasswordBox x:Name="TxtPassword"
                             Style="{StaticResource PasswordStyle}"
                             Margin="0 0 0 6"/>

                <TextBlock Text="{Binding ErrorMessage}"
                           Foreground="#EF5350"
                           FontSize="12"
                           Margin="0 0 0 20"
                           TextWrapping="Wrap"/>

                <Button Content="Sign In"
                        Command="{Binding LoginCommand}"
                        Style="{StaticResource PrimaryButton}"
                        Height="42"/>

                <TextBlock Text="Tip: click an account on the left to auto-fill"
                           Foreground="#546E7A" FontSize="10"
                           HorizontalAlignment="Center" Margin="0 16 0 0"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
